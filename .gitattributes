# Shell scripts must stay LF or they break in CI (bash chokes on CR).
*.sh text eol=lf
android/llmkit/src/main/jniLibs/**/*.so filter=lfs diff=lfs merge=lfs -text
# Prebuilt iOS llama.xcframework (binaries + dSYMs) — built by build-llama-xcframework.yml
Frameworks/** filter=lfs diff=lfs merge=lfs -text
